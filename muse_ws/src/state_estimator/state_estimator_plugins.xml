<library path="state_estimator_plugins">
  <class name="AttitudeEstimation"
         type="state_estimator_plugins::AttitudeEstimationPlugin"
         base_class_type="state_estimator_plugins::PluginBase">
    <description>Estimates base attitude from IMU measurements.</description>
  </class>
  <class name="ContactDetection"
         type="state_estimator_plugins::ContactDetectionPlugin"
         base_class_type="state_estimator_plugins::PluginBase">
    <description>Estimates foot contact from actuator state and a URDF model.</description>
  </class>
  <class name="LegOdometry"
         type="state_estimator_plugins::LegOdometryPlugin"
         base_class_type="state_estimator_plugins::PluginBase">
    <description>Calculates Pinocchio-based leg odometry.</description>
  </class>
  <class name="SensorFusion"
         type="state_estimator_plugins::SensorFusionPlugin"
         base_class_type="state_estimator_plugins::PluginBase">
    <description>Fuses attitude, acceleration, and leg odometry.</description>
  </class>
  <class name="TfPublisher"
         type="state_estimator_plugins::TfPublisherPlugin"
         base_class_type="state_estimator_plugins::PluginBase">
    <description>Publishes TF from fused odometry.</description>
  </class>
</library>
